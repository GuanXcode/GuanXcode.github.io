---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI架构原力 (AI Arch Force) — AI 场景化落地与技术架构实践' } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="GuanXcode, AI, 架构, 技术博客" />
    <meta name="theme-color" content="#0085A1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-md border-b border-[var(--color-border)]">
      <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-lg tracking-tight text-[var(--color-text)] hover:text-[var(--color-brand)] transition-colors">
          AI架构原力
        </a>
        <div class="flex items-center gap-6">
          <a href="/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">首页</a>
          <a href="/blog/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">博客</a>
          <a href="https://github.com/GuanXcode"
             target="_blank" rel="noopener noreferrer"
             class="text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] py-8 mt-20">
      <div class="max-w-5xl mx-auto px-6 text-center text-sm text-[var(--color-text-muted)]">
        <p>&copy; 2026 AI架构原力 · Powered by Astro</p>
      </div>
    </footer>
  </body>
</html>
