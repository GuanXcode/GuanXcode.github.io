---
interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  compactFooter?: boolean;
}

const { title, description = 'AI Kosei - 以工程化方法构建可生产的 AI 系统', fullWidth = false, compactFooter = false } = Astro.props;
const user = Astro.locals.user;
const shellClass = fullWidth
  ? (compactFooter ? 'w-full px-3 sm:px-4' : 'w-full px-4 sm:px-6 lg:px-8')
  : 'max-w-5xl mx-auto px-6';

import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SupportWidget from '../components/SupportWidget.astro';

const { title: finalTitle, description: finalDescription = 'AI克塞号 / AI Kosei - 以时间感知驱动智能工程' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={finalDescription} />
    <meta name="keywords" content="AI Kosei, GuanXcode, AI工程, 架构, 技术博客" />
    <meta name="theme-color" content="#F3F8FF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <title>{finalTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 bg-[var(--color-bg)]/70 backdrop-blur-md border-b border-[var(--color-border)]">
      <nav class={`${shellClass} h-16 flex items-center justify-between`}>
        <a href="/" class="flex items-center gap-3 text-[var(--color-text)] hover:text-[var(--color-brand-light)] transition-colors">
          <img src="/img/logo-kosei.svg" alt="AI Kosei" class="w-8 h-8 rounded-lg" />
          <span class="brand-display font-bold text-base md:text-lg">AI Kosei</span>
        </a>
        <div class="flex items-center gap-5 md:gap-6">
          <a href="/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">首页</a>
          <a href="/works/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">作品</a>
          <a href="/me/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">履历</a>
          {user && (
            <>
              <a href="/experience/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors hidden sm:inline">经历</a>
              <a href="/projects/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors hidden sm:inline">项目</a>
            </>
          )}
          <a href="/blog/" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors">博客</a>
          {user && (
            <a href="/auth/logout" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">退出</a>
          )}
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class={`border-t border-[var(--color-border)] ${compactFooter ? 'py-4 mt-0' : 'py-8 mt-20'}`}>
      <div class={`${shellClass} text-center text-sm text-[var(--color-text-muted)]`}>
        <p>&copy; 2026 AI Kosei · Powered by Astro</p>
      </div>
    </footer>

    <button id="support-btn" aria-label="打开联系方式" aria-expanded="false" class="support-fab" type="button">
      <span class="support-fab-glow"></span>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z"/>
      </svg>
    </button>

    <div id="support-modal" class="support-modal hidden" role="dialog" aria-modal="true" aria-labelledby="support-title">
      <div class="support-card">
        <div class="flex items-center justify-between mb-3">
          <h3 id="support-title" class="font-semibold text-[var(--color-text)]">联系 AI Kosei</h3>
          <button id="support-close" type="button" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors" aria-label="关闭弹窗">✕</button>
        </div>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">欢迎交流项目协作、技术咨询与内容合作。</p>
        <div class="space-y-2">
          <a href="mailto:guanx214@gmail.com" class="support-link">
            <span class="support-link-left">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <span>邮箱</span>
            </span>
            <span class="font-mono text-xs">guanx214@gmail.com</span>
          </a>
          <a href="https://github.com/GuanXcode" target="_blank" rel="noopener noreferrer" class="support-link">
            <span class="support-link-left">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              <span>GitHub</span>
            </span>
            <span class="font-mono text-xs">github.com/GuanXcode</span>
          </a>
        </div>
      </div>
    </div>

    <script>
      const supportBtn = document.getElementById('support-btn');
      const supportModal = document.getElementById('support-modal');
      const supportClose = document.getElementById('support-close');

      const openModal = () => {
        supportModal?.classList.remove('hidden');
        supportBtn?.setAttribute('aria-expanded', 'true');
      };
      const closeModal = () => {
        supportModal?.classList.add('hidden');
        supportBtn?.setAttribute('aria-expanded', 'false');
      };

      supportBtn?.addEventListener('click', (event) => {
        event.stopPropagation();
        if (supportModal?.classList.contains('hidden')) {
          openModal();
        } else {
          closeModal();
        }
      });

      supportClose?.addEventListener('click', closeModal);

      supportModal?.addEventListener('click', (event) => {
        if (event.target === supportModal) {
          closeModal();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeModal();
        }
      });
    </script>
  </body>
</html>
