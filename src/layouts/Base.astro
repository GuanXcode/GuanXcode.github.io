---
interface Props {
  title: string;
  description?: string;
}

import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SupportWidget from '../components/SupportWidget.astro';

const { title, description = 'AI克塞号 / AI Kosei - 以时间感知驱动智能工程' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI克塞号, AI Kosei, GuanXcode, AI工程, 架构, 技术博客" />
    <meta name="theme-color" content="#F3F8FF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader />

    <main class="flex-1">
      <slot />
    </main>

    <SiteFooter />
    <SupportWidget />
  </body>
</html>
