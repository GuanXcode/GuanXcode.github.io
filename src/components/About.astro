---
import { getCollection } from 'astro:content';

const profiles = await getCollection('profile');
const profile = profiles[0]?.data;
---

<section id="about" class="py-20 bg-[var(--color-bg-alt)]">
  <div class="max-w-5xl mx-auto px-6">
    <div class="about-panel">
      <h2 class="text-2xl font-bold tracking-tight mb-1">关于</h2>
      <p class="text-xs tracking-[0.18em] uppercase text-[var(--color-brand-light)] mb-6">站点设定</p>

      {profile?.tagline && (
        <p class="about-solo mb-6">{profile.tagline}</p>
      )}

      <blockquote class="border-l-3 border-[var(--color-brand)] pl-5 text-[var(--color-text-secondary)] text-lg mb-6 about-manifesto">
        <span class="manifesto-signal">CORE SIGNAL</span>
        <span class="manifesto-text">复杂在业务域生长，不在工具堆叠；架构师用设计原本承担担当、隔离技术、锚定演进</span>
      </blockquote>

      {profile?.publicBio && (
        <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-3xl whitespace-pre-line">
          {profile.publicBio.trim()}
        </p>
      )}

      {profile?.focusAreas && profile.focusAreas.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {profile.focusAreas.map((area) => (
            <span class="text-xs px-2.5 py-1 rounded-full border border-[var(--color-border)] bg-white text-[var(--color-text-muted)]">
              {area}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about-panel {
    position: relative;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 20px rgba(2, 132, 199, 0.06);
  }

  .about-solo {
    font-size: clamp(1.35rem, 3.4vw, 2rem);
    font-weight: 800;
    line-height: 1.3;
    color: #0b3b61;
  }

  .about-keyword {
    color: #0b67a2;
    font-weight: 700;
  }

  .about-manifesto {
    position: relative;
    overflow: hidden;
  }

  .manifesto-signal {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--color-brand);
    margin-bottom: 0.55rem;
    opacity: 0.9;
  }

  .manifesto-text {
    display: block;
    font-weight: 600;
    color: #164e7a;
    background: linear-gradient(90deg, #1e3a5f 0%, #0284c7 45%, #06b6d4 55%, #1e3a5f 100%);
    background-size: 220% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    animation: manifestoGlow 6s ease-in-out infinite;
  }

  .about-manifesto::after {
    content: "";
    position: absolute;
    top: 0;
    left: -30%;
    width: 28%;
    height: 100%;
    background: linear-gradient(110deg, transparent 0%, rgba(6, 182, 212, 0.18) 50%, transparent 100%);
    transform: skewX(-18deg);
    animation: manifestoShine 3.2s ease-in-out 0.8s 1 both;
    pointer-events: none;
  }

  .about-manifesto::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: rgba(2, 132, 199, 0.35);
    box-shadow: 0 0 8px rgba(6, 182, 212, 0.25);
    animation: manifestoScan 5.2s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes manifestoShine {
    0% {
      left: -35%;
      opacity: 0;
    }

    15% {
      opacity: 1;
    }

    70% {
      opacity: 1;
    }

    100% {
      left: 112%;
      opacity: 0;
    }
  }

  @keyframes manifestoGlow {
    0%, 100% {
      background-position: 100% 50%;
      filter: saturate(98%);
    }

    50% {
      background-position: 0% 50%;
      filter: saturate(122%);
    }
  }

  @keyframes manifestoScan {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.15;
    }

    45% {
      opacity: 0.55;
    }

    50% {
      transform: translateY(3.8rem);
      opacity: 0.65;
    }

    55% {
      opacity: 0.35;
    }
  }
</style>
