---
interface Props {
  title: string;
  items: string[];
  index?: number;
}

const { title, items, index } = Astro.props;
const code = typeof index === 'number' ? `C-${String(index + 1).padStart(2, '0')}` : null;
---

<div class="relative p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] hover:shadow-md transition-shadow">
  {code && (
    <span class="absolute top-3 right-3 text-[11px] font-mono text-[var(--color-text-muted)] tracking-widest">{code}</span>
  )}
  <h3 class="font-semibold text-base mb-3">{title}</h3>
  <ul class="space-y-1.5">
    {items.map((item) => (
      <li class="text-sm text-[var(--color-text-secondary)] flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand)] shrink-0"></span>
        {item}
      </li>
    ))}
  </ul>
</div>

<style>
  .radar-panel {
    height: 100%;
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(232, 245, 255, 0.8));
    box-shadow: 0 8px 22px rgba(2, 132, 199, 0.08);
  }

  .radar-grid {
    width: 100%;
    flex: 1;
    min-height: 260px;
    position: relative;
    border-radius: 1.2rem;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(220, 238, 255, 0.68)),
      radial-gradient(circle at 50% 50%, rgba(2, 132, 199, 0.08) 0%, rgba(2, 132, 199, 0) 72%);
  }

  .radar-hex,
  .radar-dot,
  .radar-core,
  .radar-scan {
    position: absolute;
  }

  .radar-hex {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);
    border: 1px solid rgba(2, 132, 199, 0.3);
  }

  .radar-hex.h1 {
    width: 36%;
    height: 32%;
    background: rgba(2, 132, 199, 0.04);
  }

  .radar-hex.h2 {
    width: 60%;
    height: 54%;
    background: rgba(2, 132, 199, 0.03);
  }

  .radar-hex.h3 {
    width: 86%;
    height: 78%;
    background: rgba(2, 132, 199, 0.02);
  }

  .radar-core {
    left: 50%;
    top: 50%;
    width: 14%;
    height: 14%;
    transform: translate(-50%, -50%);
    border-radius: 0.55rem;
    border: 1px solid rgba(2, 132, 199, 0.4);
    background: linear-gradient(145deg, rgba(6, 182, 212, 0.45), rgba(2, 132, 199, 0.22));
    box-shadow: 0 0 0 6px rgba(2, 132, 199, 0.08);
  }

  .radar-scan {
    left: 50%;
    top: 50%;
    width: 62%;
    height: 62%;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: conic-gradient(from 0deg, rgba(6, 182, 212, 0), rgba(6, 182, 212, 0.28), rgba(6, 182, 212, 0) 35%);
    animation: radarSweep 4.8s linear infinite;
  }

  .radar-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #0284c7;
    box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.12);
  }

  .radar-dot.d1 {
    left: 50%;
    top: 24%;
  }

  .radar-dot.d2 {
    left: 68%;
    top: 47%;
  }

  .radar-dot.d3 {
    left: 39%;
    top: 63%;
  }

  .radar-dot.d4 {
    left: 26%;
    top: 48%;
  }

  @keyframes radarSweep {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }

    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
</style>
