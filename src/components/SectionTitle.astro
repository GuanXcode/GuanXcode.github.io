---
import SectionIcon from './SectionIcon.astro';

interface Props {
  title: string;
  subtitle?: string;
  icon: 'skills' | 'projects' | 'timeline' | 'log' | 'tag' | 'article' | 'works';
}

const { title, subtitle, icon } = Astro.props;
---

<div class="flex flex-col gap-1">
  <h2 class="text-2xl font-bold tracking-tight flex items-center gap-3">
    <SectionIcon name={icon} class="w-6 h-6 text-[var(--color-brand-light)]" />
    {title}
  </h2>
  {subtitle && (
    <p class="text-xs tracking-[0.18em] uppercase text-[var(--color-brand-light)] pl-9">{subtitle}</p>
  )}
</div>
