---
interface Props {
  title: string;
  icon: 'skills' | 'projects' | 'timeline' | 'log' | 'tag' | 'article';
}

const { title, icon } = Astro.props;
---

<h2 class="text-2xl font-bold tracking-tight flex items-center gap-3">
  {icon === 'skills' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M12 4v16M6.5 6.5l11 11M17.5 6.5l-11 11" /></svg>}
  {icon === 'projects' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3.5" y="4" width="7" height="7" rx="1.5" /><rect x="13.5" y="4" width="7" height="7" rx="1.5" /><rect x="3.5" y="13" width="7" height="7" rx="1.5" /><path stroke-linecap="round" d="M17 13v7M13.5 16.5h7" /></svg>}
  {icon === 'timeline' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 18h16" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 18V9m5 9V6m5 12v-4" /><circle cx="7" cy="8" r="1" fill="currentColor" stroke="none" /><circle cx="12" cy="5" r="1" fill="currentColor" stroke="none" /><circle cx="17" cy="13" r="1" fill="currentColor" stroke="none" /></svg>}
  {icon === 'log' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="3.5" width="16" height="17" rx="2" /><path stroke-linecap="round" d="M8 8h8M8 12h8M8 16h5" /></svg>}
  {icon === 'tag' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12l-8 8-8-8V4h8l8 8z" /><circle cx="8" cy="8" r="1.2" fill="currentColor" stroke="none" /></svg>}
  {icon === 'article' && <svg class="w-6 h-6 text-[var(--color-brand-light)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 4.5h9l3 3V19.5H6z" /><path stroke-linecap="round" d="M15 4.5v3h3M9 11h6M9 14h6M9 17h4" /></svg>}
  {title}
</h2>
