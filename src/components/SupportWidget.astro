---
---

<button id="support-btn" aria-label="打开联系方式" aria-expanded="false" class="support-fab" type="button">
  <span class="support-fab-glow"></span>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z"/>
  </svg>
</button>

<div id="support-modal" class="support-modal hidden" role="dialog" aria-modal="true" aria-labelledby="support-title">
  <div class="support-card">
    <div class="flex items-center justify-between mb-3">
      <h3 id="support-title" class="font-semibold text-[var(--color-text)]">联系 AI克塞号</h3>
      <button id="support-close" type="button" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors" aria-label="关闭弹窗">✕</button>
    </div>
    <p class="text-sm text-[var(--color-text-secondary)] mb-4">欢迎交流项目协作、技术咨询与内容合作。</p>
    <div class="space-y-2">
      <a href="mailto:guanx214@gmail.com" class="support-link">
        <span class="support-link-left">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span>邮箱</span>
        </span>
        <span class="font-mono text-xs">guanx214@gmail.com</span>
      </a>
      <a href="https://github.com/GuanXcode" target="_blank" rel="noopener noreferrer" class="support-link">
        <span class="support-link-left">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span>GitHub</span>
        </span>
        <span class="font-mono text-xs">github.com/GuanXcode</span>
      </a>
    </div>
  </div>
</div>

<style>
  .support-fab {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    width: 3.35rem;
    height: 3.35rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.65);
    background: linear-gradient(145deg, #0ea5e9, #0284c7);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 28px rgba(2, 132, 199, 0.36);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }

  .support-fab-glow {
    position: absolute;
    inset: -30%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0));
    animation: supportGlow 2.6s ease-in-out infinite;
  }

  .support-fab:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 16px 34px rgba(2, 132, 199, 0.42);
  }

  .support-modal {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgba(15, 23, 42, 0.2);
    backdrop-filter: blur(2px);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1rem;
  }

  .support-modal.hidden {
    display: none;
  }

  .support-card {
    width: min(22rem, calc(100vw - 2rem));
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.16);
    padding: 1rem;
  }

  .support-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.7rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    background: #f8fbff;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .support-link-left {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .support-link:hover {
    border-color: var(--color-brand);
    color: var(--color-brand);
    background: #eef7ff;
  }

  @keyframes supportGlow {
    0%, 100% {
      transform: scale(0.9);
      opacity: 0.35;
    }

    50% {
      transform: scale(1.12);
      opacity: 0.65;
    }
  }

  @media (max-width: 640px) {
    .support-fab {
      right: 0.9rem;
      bottom: 0.9rem;
      width: 3rem;
      height: 3rem;
    }

    .support-modal {
      padding: 0.75rem;
    }
  }
</style>

<script>
  const supportBtn = document.getElementById('support-btn');
  const supportModal = document.getElementById('support-modal');
  const supportClose = document.getElementById('support-close');

  const openModal = () => {
    supportModal?.classList.remove('hidden');
    supportBtn?.setAttribute('aria-expanded', 'true');
  };

  const closeModal = () => {
    supportModal?.classList.add('hidden');
    supportBtn?.setAttribute('aria-expanded', 'false');
  };

  supportBtn?.addEventListener('click', (event) => {
    event.stopPropagation();
    if (supportModal?.classList.contains('hidden')) {
      openModal();
    } else {
      closeModal();
    }
  });

  supportClose?.addEventListener('click', closeModal);

  supportModal?.addEventListener('click', (event) => {
    if (event.target === supportModal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeModal();
    }
  });
</script>
