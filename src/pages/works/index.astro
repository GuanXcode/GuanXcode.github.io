---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getCollection, render } from 'astro:content';

const worksList = (await getCollection('works')).sort((a, b) => a.data.order - b.data.order);

const workEntries = await Promise.all(
  worksList.map(async (work) => {
    const { Content } = await render(work);
    return { work, Content };
  }),
);

const typeLabels: Record<string, string> = {
  demo: 'Demo',
  design: '设计',
  talk: '演讲',
  article: '文章',
  repo: '仓库',
  other: '其他',
};
---

<Base title="作品 - AI克塞号 / AI Kosei">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <a href="/me/" class="inline-flex text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand)] mb-6">&larr; 返回履历总览</a>
      <SectionTitle title="作品陈列" icon="projects" />
      <p class="text-sm text-[var(--color-text-secondary)] mt-2 mb-10">设计、Demo、演讲与仓库等个人作品（仅授权访客可见）。</p>

      <div class="space-y-6">
        {workEntries.map(({ work, Content }) => (
          <article class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)]/90 p-6 md:p-8 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
              <h2 class="text-lg font-bold">
                {work.data.url ? (
                  <a href={work.data.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-brand)]">
                    {work.data.title}
                  </a>
                ) : (
                  work.data.title
                )}
              </h2>
              <span class="text-xs px-2 py-0.5 rounded bg-[var(--color-bg-alt)] text-[var(--color-text-muted)]">
                {typeLabels[work.data.type] ?? work.data.type}
              </span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] mb-4">{work.data.description}</p>
            {work.data.image && (
              <img src={work.data.image} alt="" class="w-full max-h-64 object-cover rounded-lg mb-4 border border-[var(--color-border)]" />
            )}
            <div class="prose text-sm">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
