---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getCollection } from 'astro:content';
import { filterVisibleWorks } from '../../lib/content';

const user = Astro.locals.user;
const isAuthed = Boolean(user);

const worksList = filterVisibleWorks(await getCollection('works'), isAuthed).sort(
  (a, b) => a.data.order - b.data.order,
);

const typeLabels: Record<string, string> = {
  demo: 'Demo',
  design: '设计',
  talk: '演讲',
  article: '文章',
  repo: '仓库',
  other: '其他',
};

const backHref = isAuthed ? '/me/' : '/';
const backLabel = isAuthed ? '返回履历总览' : '返回首页';
---

<Base title="作品 - AI克塞号 / AI Kosei">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <a href={backHref} class="inline-flex text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand)] mb-6">&larr; {backLabel}</a>
      <SectionTitle title="作品" subtitle={isAuthed ? '全部作品' : '公开展示'} icon="works" />
      <p class="text-sm text-[var(--color-text-secondary)] mt-2 mb-10">
        {isAuthed
          ? '含公开与仅授权可见的作品条目。'
          : '以下为公开作品。登录后可查看完整作品库。'}
      </p>

      {worksList.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {worksList.map((work) => (
            <WorkCard
              title={work.data.title}
              description={work.data.description}
              type={typeLabels[work.data.type] ?? work.data.type}
              slug={work.id}
              url={work.data.url}
              publicBadge={work.data.visibility === 'public'}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--color-text-muted)]">暂无公开展示的作品。</p>
      )}

      {!isAuthed && (
        <p class="text-sm text-[var(--color-text-muted)] mt-8">
          <a href="/login?next=/works/" class="text-[var(--color-brand)] hover:underline">登录</a>
          {' '}查看完整作品库。
        </p>
      )}
    </div>
  </section>
</Base>
