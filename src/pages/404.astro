---
import Base from '../layouts/Base.astro';
---

<Base title="404 — AI架构原力">
  <section class="py-32 text-center">
    <div class="max-w-lg mx-auto px-6">
      <p class="text-8xl font-bold text-[var(--color-border)] mb-4">404</p>
      <p class="text-lg text-[var(--color-text-secondary)] mb-8">你来到了没有知识的荒原</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-sm hover:opacity-90 transition-opacity">
        &larr; 返回首页
      </a>
    </div>
  </section>
</Base>
