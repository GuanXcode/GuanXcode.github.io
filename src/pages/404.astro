---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
---

<Base title="404 - AI Kosei">
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)]/90 p-8 md:p-10 shadow-sm text-center">
        <p class="text-7xl font-bold text-[var(--color-brand-light)] mb-4 brand-display">404</p>
        <div class="flex justify-center mb-3">
          <SectionTitle title="坐标未建立" icon="tag" />
        </div>
        <p class="text-[var(--color-text-secondary)] mb-8">你访问的页面尚未部署到当前时空航线。</p>
        <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-brand)] text-white text-sm hover:opacity-90 transition-opacity">
          &larr; 返回首页
        </a>
      </div>
    </div>
  </section>
</Base>
