---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/projects');

const project = await getEntry('projects', slug);
if (!project) return Astro.redirect('/projects');

const { Content } = await render(project);
---

<Base title={`${project.data.title} - 项目`}>
  <article class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <a href="/projects/" class="inline-flex text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand)] mb-6">&larr; 返回项目列表</a>
      <header class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)]/90 p-6 md:p-8 shadow-sm mb-8">
        <SectionTitle title={project.data.title} icon="projects" />
        <p class="text-[var(--color-text-secondary)] mt-3">{project.data.description}</p>
        {project.data.role && (
          <p class="text-sm text-[var(--color-brand)] mt-3">角色：{project.data.role}</p>
        )}
        <div class="flex flex-wrap gap-1.5 mt-4">
          {project.data.tech.map((t) => (
            <span class="text-xs px-2 py-0.5 rounded bg-[var(--color-bg-alt)] text-[var(--color-text-muted)]">{t}</span>
          ))}
        </div>
        {project.data.url && (
          <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-sm text-[var(--color-brand)] hover:underline">
            查看外链 &rarr;
          </a>
        )}
      </header>
      {project.data.image && (
        <img src={project.data.image} alt="" class="w-full rounded-xl mb-8 border border-[var(--color-border)]" />
      )}
      <div class="prose rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)]/85 p-6 md:p-8">
        <Content />
      </div>
    </div>
  </article>
</Base>
