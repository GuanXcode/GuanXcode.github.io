---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base title="项目 - AI Kosei">
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <a href="/me/" class="inline-flex text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand)] mb-6">&larr; 返回履历总览</a>
      <SectionTitle title="项目" subtitle="任务编队 · 概要" icon="projects" />
      <p class="text-sm text-[var(--color-text-secondary)] mt-2 mb-10 pl-9">仅含总结与设计方案简述，不含实现细节（授权访客可见）。</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {allProjects.map((project) => (
          <a href={`/projects/${project.id}/`} class="block">
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tech={project.data.tech}
              image={project.data.image}
            />
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
