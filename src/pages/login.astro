---
import Base from '../layouts/Base.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
const next = Astro.url.searchParams.get('next') ?? '/me';

const errorMessages: Record<string, string> = {
  not_allowed: '你的 GitHub 账号不在访问白名单中。如需查看履历，请联系站点所有者。',
  oauth_denied: '你已取消 GitHub 授权。',
  oauth_failed: 'GitHub 登录失败，请稍后重试。',
  invalid_state: '登录状态已过期，请重新登录。',
  config: '站点 OAuth 尚未配置完成。',
};

const errorText = error ? errorMessages[error] ?? '登录出现问题，请重试。' : null;
const loginHref = `/auth/github?next=${encodeURIComponent(next)}`;
---

<Base title="登录 - AI Kosei" description="使用 GitHub 登录查看职业经历与项目作品">
  <section class="py-24">
    <div class="max-w-md mx-auto px-6 text-center">
      <img src="/img/logo-kosei.svg" alt="" class="w-16 h-16 rounded-xl mx-auto mb-6 border border-[var(--color-border)]" />
      <h1 class="text-2xl font-bold mb-1">登录</h1>
      <p class="text-xs tracking-[0.14em] uppercase text-[var(--color-brand-light)] mb-4">授权访问</p>
      <p class="text-sm text-[var(--color-text-secondary)] mb-8 leading-relaxed">
        职业经历与项目概要需 GitHub 白名单登录。公开作品与博客无需登录即可浏览。
      </p>

      {errorText && (
        <p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-6" role="alert">
          {errorText}
        </p>
      )}

      <a
        href={loginHref}
        class="inline-flex items-center justify-center gap-2 w-full px-5 py-3 rounded-lg bg-[var(--color-brand)] text-white text-sm font-medium hover:opacity-90 transition-opacity"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        使用 GitHub 继续
      </a>

      <p class="mt-6 text-xs text-[var(--color-text-muted)]">
        <a href="/" class="hover:text-[var(--color-brand)] transition-colors">&larr; 返回公开首页</a>
      </p>
    </div>
  </section>
</Base>
