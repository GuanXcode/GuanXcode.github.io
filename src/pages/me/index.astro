---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import ProfileHeader from '../../components/ProfileHeader.astro';
import Skills from '../../components/Skills.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import WorkCard from '../../components/WorkCard.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getCollection } from 'astro:content';

const user = Astro.locals.user!;

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const featuredProjects = allProjects.filter((p) => p.data.featured);
const displayProjects =
  featuredProjects.length > 0 ? featuredProjects : allProjects.slice(0, 3);

const experiences = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order,
);

const privateWorks = (await getCollection('works'))
  .filter((w) => w.data.visibility === 'private')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const typeLabels: Record<string, string> = {
  demo: 'Demo',
  design: '设计',
  talk: '演讲',
  article: '文章',
  repo: '仓库',
  other: '其他',
};

const skills = [
  { title: '架构设计', items: ['分布式系统', '微服务架构', '领域驱动设计 (DDD)', '系统建模'] },
  { title: '后端开发', items: ['Java', 'Python', 'Go', 'SQL / NoSQL'] },
  { title: 'AI 工程', items: ['LLM 应用开发', 'RAG 知识检索', 'AI Agent', 'Prompt Engineering'] },
  { title: 'DevOps', items: ['CI/CD 流水线', 'Docker / K8s', '云原生', '可观测性'] },
];
---

<Base title="履历总览 - AI克塞号 / AI Kosei">
  <ProfileHeader user={user} />

  {experiences.length > 0 && (
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-6">
          <SectionTitle title="经历" subtitle="职业时间线" icon="timeline" />
          <a href="/experience/" class="text-sm text-[var(--color-brand)] hover:underline">完整经历 &rarr;</a>
        </div>
        <ul class="space-y-4">
          {experiences.slice(0, 2).map((exp) => (
            <li class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)]">
              <div class="flex flex-wrap justify-between gap-2 mb-1">
                <h3 class="font-semibold">{exp.data.company}</h3>
                <span class="text-sm text-[var(--color-text-muted)]">
                  {exp.data.start}{exp.data.end ? ` — ${exp.data.end}` : ''}
                </span>
              </div>
              <p class="text-sm text-[var(--color-brand)] mb-2">{exp.data.role}</p>
              {exp.data.highlights[0] && (
                <p class="text-sm text-[var(--color-text-secondary)]">{exp.data.highlights[0]}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {displayProjects.length > 0 && (
    <section id="projects" class="py-16 bg-[var(--color-bg-alt)]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <SectionTitle title="项目" subtitle="任务编队 · 概要" icon="projects" />
          <a href="/projects/" class="text-sm text-[var(--color-brand)] hover:underline">全部项目 &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {displayProjects.map((project) => (
            <a href={`/projects/${project.id}/`} class="block">
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                image={project.data.image}
              />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {privateWorks.length > 0 && (
    <section class="py-16">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <SectionTitle title="作品" subtitle="仅授权可见" icon="works" />
          <a href="/works/" class="text-sm text-[var(--color-brand)] hover:underline">全部作品 &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {privateWorks.map((work) => (
            <WorkCard
              title={work.data.title}
              description={work.data.description}
              type={typeLabels[work.data.type] ?? work.data.type}
              slug={work.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="skills" class="py-20 bg-[var(--color-bg-alt)]">
    <div class="max-w-5xl mx-auto px-6">
      <SectionTitle title="技能" subtitle="能力坐标" icon="skills" />
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-6 items-stretch mt-8">
        <aside class="radar-panel">
          <div class="radar-grid">
            <span class="radar-hex h1"></span>
            <span class="radar-hex h2"></span>
            <span class="radar-hex h3"></span>
            <span class="radar-scan"></span>
            <span class="radar-core"></span>
            <span class="radar-dot d1"></span>
            <span class="radar-dot d2"></span>
            <span class="radar-dot d3"></span>
            <span class="radar-dot d4"></span>
          </div>
          <p class="text-xs text-[var(--color-text-secondary)] mt-4">能力矩阵在线校准中</p>
        </aside>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 h-full">
          {skills.map((s, i) => <Skills title={s.title} items={s.items} index={i} />)}
        </div>
      </div>
    </div>
  </section>
</Base>
