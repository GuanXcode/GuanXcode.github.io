---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import Skills from '../../components/Skills.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PostCard from '../../components/PostCard.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { getCollection } from 'astro:content';

const user = Astro.locals.user!;

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = allPosts.slice(0, 3);

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const featuredProjects = allProjects.filter((p) => p.data.featured);
const displayProjects =
  featuredProjects.length > 0 ? featuredProjects : allProjects.slice(0, 3);

const experiences = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order,
);

const skills = [
  { title: '架构设计', items: ['分布式系统', '微服务架构', '领域驱动设计 (DDD)', '系统建模'] },
  { title: '后端开发', items: ['Java', 'Python', 'Go', 'SQL / NoSQL'] },
  { title: 'AI 工程', items: ['LLM 应用开发', 'RAG 知识检索', 'AI Agent', 'Prompt Engineering'] },
  { title: 'DevOps', items: ['CI/CD 流水线', 'Docker / K8s', '云原生', '可观测性'] },
];
---

<Base title="履历总览 - AI克塞号 / AI Kosei">
  <section class="py-12 border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-6 flex items-center gap-4">
      {user.avatar && (
        <img src={user.avatar} alt="" class="w-12 h-12 rounded-full border border-[var(--color-border)]" />
      )}
      <div>
        <p class="text-sm text-[var(--color-text-muted)]">已授权访问</p>
        <h1 class="text-xl font-bold">欢迎，{user.name}</h1>
        <p class="text-sm text-[var(--color-text-secondary)]">@{user.login}</p>
      </div>
    </div>
  </section>

  <section id="skills" class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="mb-8 flex items-center justify-between">
        <SectionTitle title="能力坐标" icon="skills" />
        <a href="/experience/" class="text-sm text-[var(--color-brand)] hover:underline">完整经历 &rarr;</a>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-6 items-stretch">
        <aside class="radar-panel">
          <div class="radar-grid">
            <span class="radar-hex h1"></span>
            <span class="radar-hex h2"></span>
            <span class="radar-hex h3"></span>
            <span class="radar-scan"></span>
            <span class="radar-core"></span>
            <span class="radar-dot d1"></span>
            <span class="radar-dot d2"></span>
            <span class="radar-dot d3"></span>
            <span class="radar-dot d4"></span>
          </div>
          <p class="text-xs text-[var(--color-text-secondary)] mt-4">能力矩阵在线校准中</p>
        </aside>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 h-full">
          {skills.map((s, i) => <Skills title={s.title} items={s.items} index={i} />)}
        </div>
      </div>
    </div>
  </section>

  {experiences.length > 0 && (
    <section class="py-16 bg-[var(--color-bg-alt)]">
      <div class="max-w-5xl mx-auto px-6">
        <SectionTitle title="职业经历摘要" icon="timeline" />
        <ul class="mt-6 space-y-4">
          {experiences.slice(0, 2).map((exp) => (
            <li class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)]">
              <div class="flex flex-wrap justify-between gap-2 mb-1">
                <h3 class="font-semibold">{exp.data.company}</h3>
                <span class="text-sm text-[var(--color-text-muted)]">
                  {exp.data.start}{exp.data.end ? ` — ${exp.data.end}` : ''}
                </span>
              </div>
              <p class="text-sm text-[var(--color-brand)] mb-2">{exp.data.role}</p>
              {exp.data.highlights[0] && (
                <p class="text-sm text-[var(--color-text-secondary)]">{exp.data.highlights[0]}</p>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {displayProjects.length > 0 && (
    <section id="projects" class="py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <SectionTitle title="任务编队" icon="projects" />
          <a href="/projects/" class="text-sm text-[var(--color-brand)] hover:underline">全部项目 &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {displayProjects.map((project) => (
            <a href={`/projects/${project.id}/`} class="block">
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                url={project.data.url}
                image={project.data.image}
              />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="py-20 bg-[var(--color-bg-alt)]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <SectionTitle title="时间线日志" icon="timeline" />
          <a href="/blog/" class="text-sm text-[var(--color-brand)] hover:underline">全部文章 &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              excerpt={post.data.subtitle || post.body?.replace(/<[^>]*>/g, '').replace(/[#*>`\[\]()!]/g, '').trim().slice(0, 120)}
              date={post.data.date}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</Base>
