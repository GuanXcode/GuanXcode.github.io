---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import Contact from '../components/Contact.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentPosts = allPosts.slice(0, 3);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const featuredProjects = allProjects.filter((p) => p.data.featured);
const displayProjects = featuredProjects.length > 0 ? featuredProjects : allProjects.slice(0, 3);

const skills = [
  { title: '架构设计', items: ['分布式系统', '微服务架构', '领域驱动设计 (DDD)', '系统建模'] },
  { title: '后端开发', items: ['Java', 'Python', 'Go', 'SQL / NoSQL'] },
  { title: 'AI 工程', items: ['LLM 应用开发', 'RAG 知识检索', 'AI Agent', 'Prompt Engineering'] },
  { title: 'DevOps', items: ['CI/CD 流水线', 'Docker / K8s', '云原生', '可观测性'] },
];
---

<Base title="木瓜匣AI - GuanXcode">
  <Hero />

  <About />

  <section id="skills" class="py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold tracking-tight mb-8">技能</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {skills.map((s) => <Skills title={s.title} items={s.items} />)}
      </div>
    </div>
  </section>

  {displayProjects.length > 0 && (
    <section id="projects" class="py-20 bg-[var(--color-bg-alt)]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">精选项目</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {displayProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              tech={project.data.tech}
              url={project.data.url}
              image={project.data.image}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight">最新文章</h2>
          <a href="/blog/" class="text-sm text-[var(--color-brand)] hover:underline">全部文章 &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              excerpt={post.data.subtitle || post.body?.replace(/<[^>]*>/g, '').replace(/[#*>`\[\]()!]/g, '').trim().slice(0, 120)}
              date={post.data.date}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <Contact />
</Base>
