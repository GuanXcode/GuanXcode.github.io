---
export const prerender = false;

import Base from '../layouts/Base.astro';
import HomeDashboard from '../components/HomeDashboard.astro';
import { getCollection } from 'astro:content';
import { filterVisibleWorks } from '../lib/content';

const user = Astro.locals.user;
const isAuthed = Boolean(user);

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = allPosts.slice(0, 3);

const typeLabels: Record<string, string> = {
  demo: 'Demo',
  design: '设计',
  talk: '演讲',
  article: '文章',
  repo: '仓库',
  other: '其他',
};

const allWorks = await getCollection('works');
const publicWorks = filterVisibleWorks(allWorks, isAuthed)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const privateWorkCount = isAuthed
  ? 0
  : allWorks.filter((w) => w.data.visibility === 'private').length;
---

<Base title="AI Kosei" compactFooter>
  <div class="max-w-5xl mx-auto px-6">
    <HomeDashboard
    user={user}
    publicWorks={publicWorks}
    recentPosts={recentPosts}
    typeLabels={typeLabels}
    privateWorkCount={privateWorkCount}
    />
  </div>
</Base>
